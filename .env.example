# Copia este archivo a .env y ajusta los valores

# Nombre único del proyecto — se usa en container_name, labels de Traefik
# y nombres de volúmenes. Sin espacios ni caracteres especiales.
PROJECT_NAME=miodoo

# Dominio principal expuesto por Traefik
MAIN_HOST=odoo.midominio.com

# Base de datos
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=cambiame

# Contraseña maestra de Odoo
ODOO_ADMIN_PASSWORD=cambiame
